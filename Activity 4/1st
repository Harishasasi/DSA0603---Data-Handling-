# Student Marks
marks <- c(45, 52, 58, 60, 65, 68, 72, 75, 80, 90)

# Create ECDF
ecdf_marks <- ecdf(marks)

# Display cumulative probabilities
sorted_marks <- sort(marks)
cum_prob <- ecdf_marks(sorted_marks)

data.frame(
  Marks = sorted_marks,
  Cumulative_Probability = cum_prob
)

# ECDF Plot
plot(ecdf_marks,
     main = "ECDF of Student Marks",
     xlab = "Marks",
     ylab = "Cumulative Probability",
     verticals = TRUE,
     do.points = TRUE,
     col = "blue",
     lwd = 2)

grid()
