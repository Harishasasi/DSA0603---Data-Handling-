# Monthly Income
income <- c(18000, 22000, 24000, 26000, 28000,
            30000, 34000, 42000, 85000, 200000)

# Histogram
hist(income,
     probability = TRUE,
     col = "lightgreen",
     main = "Histogram of Monthly Income",
     xlab = "Monthly Income (₹)",
     border = "black")

# Density Curve
lines(density(income),
      col = "blue",
      lwd = 2)

grid()
