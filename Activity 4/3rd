# Purchase Amounts
purchase <- c(250, 300, 320, 350, 380,
              450, 520, 650, 1800, 5200)

# Histogram
hist(purchase,
     probability = TRUE,
     col = "lightblue",
     main = "Histogram of Purchase Amount",
     xlab = "Purchase Amount (₹)",
     border = "black")

# Density Curve
lines(density(purchase),
      col = "red",
      lwd = 2)

grid()
